# GraphQuest secrets — copy to `.env` and fill in. NEVER commit the real .env.
# (V3 §7.4: API keys live only in environment variables, read via os.environ.get)

# LLM provider used by BOTH the Graphify semantic layer and the LangGraph debug agent.
# DeepSeek is OpenAI-compatible and cheap (matches the token-efficiency theme).
OPENAI_API_KEY=sk-your-key-here
OPENAI_BASE_URL=https://api.deepseek.com/v1
GRAPHQUEST_MODEL=deepseek-chat

# Optional: separate key for the semantic-inference pass if you want isolation.
# GRAPHQUEST_SEMANTIC_API_KEY=sk-...
