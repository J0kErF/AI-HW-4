{
  "version": "1.00",
  "project": {
    "name": "graphquest",
    "group_code": "moamteam",
    "course": "Building with LLMs — Dr. Yoram Segal",
    "assignment": "HW4 / EX04 — Reverse Engineering, Debugging and Token-Efficient Agentic AI"
  },
  "target": {
    "comment": "Unfamiliar Python codebase under study. Pinned in Phase 1 to cookiecutter bug 2 (cross-platform reproducible; root cause spans run_hook->find_hook, a changed return contract = strong graph-navigation demo). Fallback bug 1 (one-line encoding fix, bulletproof repro). Larger-codebase alternative for a bigger token delta: thefuck.",
    "source": "bugsinpy",
    "project": "cookiecutter",
    "bug_id": "2",
    "github_url": "https://github.com/cookiecutter/cookiecutter",
    "buggy_commit_id": "d7e7b28811e474e14d1bed747115e47dcdd15ba3",
    "fixed_commit_id": "90434ff4ea4477941444f1e83313beb414838535",
    "test_file": "tests/test_hooks.py",
    "test_selectors": [
      "tests/test_hooks.py::TestFindHooks::test_find_hook",
      "tests/test_hooks.py::TestExternalHooks::test_run_hook"
    ],
    "python_version": "3.6.9",
    "fallback_bug_id": "1",
    "larger_alternative_project": "thefuck",
    "checkout_dir": "data/target_repo",
    "default_ref": "buggy"
  },
  "graphify": {
    "scan_root": "data/target_repo",
    "include_globs": ["**/*.py"],
    "exclude_globs": ["**/.git/**", "**/__pycache__/**", "**/build/**", "**/docs/**", "**/setup.py", "**/conftest.py"],
    "semantic_layer_enabled": true,
    "semantic_max_nodes": 40,
    "confidence_thresholds": {
      "extracted": 0.9,
      "inferred": 0.7,
      "ambiguous": 0.55
    },
    "outputs_dir": "artifacts",
    "vault_dir": "obsidian/wiki"
  },
  "agent": {
    "framework": "langgraph",
    "model_env": "GRAPHQUEST_MODEL",
    "max_iterations": 6,
    "hot_md": "obsidian/wiki/hot.md",
    "index_md": "obsidian/wiki/index.md",
    "graph_json": "artifacts/graph.json"
  },
  "benchmark": {
    "comment": "Both arms run the SAME model, task and stopping criterion. Only the retrieval policy differs (see docs/PRD_token_benchmark.md).",
    "model_env": "GRAPHQUEST_MODEL",
    "stopping_criterion": "root_cause_localized_to_function",
    "max_iterations": 10,
    "report_path": "reports/TOKEN_REPORT.md"
  }
}
